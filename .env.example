# Exemple de variables d'environnement pour Fly.io
# Copier dans Fly.io via: flyctl secrets set KEY=value

# API Groq (requis)
GROQ_API_KEY=sk-your-groq-key-here

# API DeepL (optionnel)
DEEPL_API_KEY=your-deepl-key-here

# Hugging Face Hub (pour télécharger les modèles NLLB)
HF_TOKEN=hf_your_token_here

# Modèle NLLB (optionnel)
NLLB_MODEL=amazon/nllb-200-distilled-600M
NLLB_DEVICE=-1
